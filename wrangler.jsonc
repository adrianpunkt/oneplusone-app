{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "oneplusoneclub-app-dev",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-17",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "app.oneplusoneclub.com",
      "custom_domain": true
    }
  ],
  "vars": {
    "NEXT_PUBLIC_APP_URL": "https://app.oneplusoneclub.com"
  },
  "env": {
    "dev": {
      "name": "oneplusoneclub-app-dev",
      "routes": [
        {
          "pattern": "dev-app.oneplusoneclub.com",
          "custom_domain": true
        }
      ],
      "vars": {
        "NEXT_PUBLIC_APP_URL": "https://dev-app.oneplusoneclub.com"
      }
    }
  }
}
