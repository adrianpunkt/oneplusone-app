<Style themeId="cmqb4vmha00o10ju4ths91501" />
<Component componentId="cmqcao6dm1wwz0kys84vjjm7h" paddingTop="20" paddingBottom="30">
  <Image src="https://images.vialoops.com/cmqb4p85p00er0jx8l4k4zg0h/cmqlfw8ho03sf0jxsbxf18x0a.png" alt="Dear {data.firstName}," width="202" dynamicSrc="https://oneplusoneclub.com/email/en/welcome/{data.firstName}.png" paddingTop="20" paddingBottom="30" />
</Component>
<Paragraph>We've received your cancellation and updated your place for this event.</Paragraph>
<Paragraph></Paragraph>
<Section blockColor="#fef9f9" blockBorderRadius="12" paddingTop="16" paddingRight="16" paddingBottom="16" paddingLeft="16">
  <Paragraph><Strong>What happens now</Strong><Br />{data.cancellationOutcome}</Paragraph>
  <Paragraph><Strong>Reason recorded:</Strong> {data.cancellationReason}</Paragraph>
</Section>
<Paragraph></Paragraph>
<Button href="{data.ctaUrl}">View your events</Button>
<Component componentId="cmqcdwxlt1oyx0jxfjrrwxls0" paddingTop="20" paddingBottom="20">
  <Image src="https://images.vialoops.com/cmqb4p85p00er0jx8l4k4zg0h/cmqlg3fsz050i0jxqp5h3c8c0.png" alt="one plus one club" href="https://oneplusoneclub.com" width="222" dynamicSrc="https://oneplusoneclub.com/email/en/with-love-oneplusoneclub.png" paddingTop="20" paddingBottom="20" />
</Component>
<Component componentId="cmql90bd02j7r0j05fsp2h0dt">
  <Paragraph fontSize="16" lineHeight="150"><Text textColor="#440a12">P.S. You can follow us on Instagram </Text><Link href="https://www.instagram.com/oneplusone_club?utm_source=friends-email"><Underline>@oneplusone_club</Underline></Link></Paragraph>
</Component>
